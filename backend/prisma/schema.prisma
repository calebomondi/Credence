datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Commitment {
  id          String   @id @default(cuid())
  stellarUser String
  commitment  String
  tier        Int
  nonce       String
  proofHash   String   @default("")
  createdAt   DateTime @default(now())
}

model WalletLink {
  id            String   @id @default(cuid())
  userId        String
  email         String
  walletAddress String
  signature     String?
  status        String   @default("verified")
  verifiedAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([walletAddress])
}

model IssuedPassport {
  id            String   @id @default(cuid())
  userEmail     String
  commitment    String
  tier          Int
  verifiedAt    DateTime
  proofHash     String
  combinedScore Int
  scoreLevel    String
  walletCount   Int
  createdAt     DateTime @default(now())
}
